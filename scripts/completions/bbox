#compdef bbox

_bbox() {
    local state

    _arguments \
        '1:command:->command' \
        '*:args:->args'

    case "$state" in
        command)
            local commands=(
                'e:Encrypt a file'
                'encrypt:Encrypt a file'
                'd:Decrypt a file'
                'decrypt:Decrypt a file'
            )
            _describe 'command' commands
            ;;
        args)
            case "$words[2]" in
                e|encrypt)
                    _arguments \
                        '-o[Output file path]:output file:_files' \
                        ':input file:_files'
                    ;;
                d|decrypt)
                    _arguments \
                        '-o[Output file path]:output file:_files' \
                        ':encrypted file:_files -g "*.bbox"'
                    ;;
            esac
            ;;
    esac
}

_bbox "$@"
