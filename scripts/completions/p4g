#compdef p4g

_p4g() {
  local state

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1:command:->commands' && return 0

  case $state in
    commands)
      local -a completions=(
        'proj:fzf-select and switch GCP project'
        'project:fzf-select and switch GCP project'
        'acct:fzf-select gcloud account'
        'account:fzf-select gcloud account'
        'login:Run gcloud auth login + application-default login'
        'status:Show current project and account'
        's:Show current project and account'
      )
      _describe 'p4g commands' completions
      ;;
  esac
}

_p4g "$@"
